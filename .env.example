# ===========================================================================
# Copy this file to ".env" and fill in ONE provider (or none).
#
# IMPORTANT: you do NOT need any key to learn the core of RAG.
# Loading, chunking, embedding, storing and retrieving all run locally and free.
# A key is only needed for the final GENERATE step. With no key, the lab runs in
# "dry run" mode and shows you the exact prompt it would have sent.
# ===========================================================================

# Which provider to use for generation: anthropic | openai | ollama
LLM_PROVIDER=anthropic

# --- Option A: Anthropic (Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Option B: OpenAI ---
# Set LLM_PROVIDER=openai above, then:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Option C: Ollama (fully local, no key) ---
# Install Ollama, run `ollama pull llama3.1:8b`, set LLM_PROVIDER=ollama above.
OLLAMA_MODEL=llama3.1:8b
